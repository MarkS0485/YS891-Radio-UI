<Window x:Class="YS891.RadioUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:YS891.RadioUI.Controls"
        xmlns:views="clr-namespace:YS891.RadioUI.Views"
        xmlns:conv="clr-namespace:YS891.RadioUI.Converters"
        Title="YS891 Radio UI — Yaesu FT-891"
        Width="1240" Height="720"
        MinWidth="1080" MinHeight="620"
        Background="{StaticResource BezelBrush}">

    <Window.Resources>
        <conv:BoolToBrushConverter x:Key="TxLampBrush"
                                   OnBrush="{StaticResource TxActiveBrush}"
                                   OffBrush="{StaticResource TxIdleBrush}" />
        <conv:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <conv:BoolToVisibilityConverter x:Key="HiddenWhenFalse" WhenFalse="Hidden" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Top bar: branding + connection ===== -->
        <Border Grid.Row="0" Background="{StaticResource StatusBarBrush}" Padding="12,6">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="YAESU" FontFamily="Arial Black" FontSize="18"
                               Foreground="{StaticResource ButtonTextBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="  FT-891" FontFamily="Segoe UI" FontWeight="Light" FontSize="16"
                               Foreground="{StaticResource LcdDimTextBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="  HF/50 MHz TRANSCEIVER — FULL FEATURE DEMO" FontSize="9"
                               Foreground="{StaticResource LcdDimTextBrush}" VerticalAlignment="Center" Margin="6,4,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding ConnectionDescription}" Foreground="{StaticResource LcdDimTextBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0" />
                    <ToggleButton x:Name="DiscoToggle" Content="DISCO" Style="{StaticResource PanelToggle}"
                                  Margin="0,0,10,0" Checked="OnDiscoToggle" Unchecked="OnDiscoToggle"
                                  ToolTip="1986 called. It approves. (Esc exits)" />
                    <Button Content="CONNECT" Style="{StaticResource PanelButton}" Click="OnConnectClick" />
                    <Button Content="DISCONNECT" Style="{StaticResource PanelButton}" Margin="6,0,0,0"
                            Command="{Binding DisconnectCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== Tabs ===== -->
        <TabControl Grid.Row="1" x:Name="Tabs" Margin="6,0,6,0">

            <!-- ============ PANEL ============ -->
            <TabItem Header="PANEL">
                <Border Background="{StaticResource FasciaBrush}"
                        BorderBrush="{StaticResource PanelEdgeBrush}" BorderThickness="1"
                        CornerRadius="10" Margin="4" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: MULTI knob + function keys -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                                <controls:RotaryDial x:Name="MultiKnob" Width="92" Height="92" />
                                <Button Content="{Binding MultiText}" Style="{StaticResource PanelButton}"
                                        Command="{Binding MultiSelectCommand}" Margin="0,8,0,0"
                                        ToolTip="MULTI — click to select AF / RF / MIC / SQL / PWR, turn knob to adjust" />
                            </StackPanel>

                            <UniformGrid Grid.Row="1" Columns="2" Margin="0,16,0,0">
                                <Button Content="{Binding StepText}" Style="{StaticResource PanelButton}"
                                        Command="{Binding StepCommand}" Margin="2" ToolTip="Cycle dial step" />
                                <Button Content="LOCK" Style="{StaticResource PanelLitButton}"
                                        Tag="{Binding IsLocked}" Command="{Binding LockCommand}" Margin="2" />
                                <Button Content="{Binding AgcText}" Style="{StaticResource PanelButton}"
                                        Command="{Binding AgcCommand}" Margin="2" ToolTip="Cycle AGC" />
                                <Button Content="NB" Style="{StaticResource PanelLitButton}"
                                        Tag="{Binding NbOn}" Command="{Binding NbCommand}" Margin="2" />
                                <Button Content="NR" Style="{StaticResource PanelLitButton}"
                                        Tag="{Binding NrOn}" Command="{Binding NrCommand}" Margin="2" />
                                <Button Content="SPL" Style="{StaticResource PanelLitButton}"
                                        Tag="{Binding IsSplit}" Command="{Binding SplitCommand}" Margin="2" />
                            </UniformGrid>

                            <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                                <TextBlock Text="BAND" Foreground="{StaticResource LcdDimTextBrush}"
                                           FontFamily="Consolas" FontSize="10" Margin="2,0" />
                                <ComboBox x:Name="BandCombo" Margin="2,2" SelectionChanged="OnBandPick"
                                          ToolTip="Jump to a band via the band-stacking registers" />
                            </StackPanel>
                        </Grid>

                        <!-- Centre: LCD + soft keys -->
                        <Grid Grid.Column="1" Margin="14,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{StaticResource LcdBackgroundBrush}"
                                    BorderBrush="{StaticResource BezelBrush}" BorderThickness="3"
                                    CornerRadius="6" Padding="12,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                            <TextBlock Text="{Binding ModeText}" FontFamily="Consolas" FontSize="16"
                                                       Foreground="{StaticResource LcdAccentBrush}" />
                                            <TextBlock Text="{Binding AgcText}" FontFamily="Consolas" FontSize="12"
                                                       Foreground="{StaticResource LcdDimTextBrush}" Margin="14,3,0,0" />
                                            <TextBlock Text="{Binding StepText}" FontFamily="Consolas" FontSize="12"
                                                       Foreground="{StaticResource LcdDimTextBrush}" Margin="14,3,0,0" />
                                            <TextBlock Text="LOCK" FontFamily="Consolas" FontSize="12" Margin="14,3,0,0"
                                                       Foreground="{StaticResource IndicatorOnBrush}"
                                                       Visibility="{Binding IsLocked, Converter={StaticResource HiddenWhenFalse}}" />
                                            <TextBlock Text="SPLIT" FontFamily="Consolas" FontSize="12" Margin="14,3,0,0"
                                                       Foreground="{StaticResource IndicatorOnBrush}"
                                                       Visibility="{Binding IsSplit, Converter={StaticResource HiddenWhenFalse}}" />
                                            <TextBlock Text="TX" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Margin="14,3,0,0"
                                                       Foreground="{StaticResource MeterRedBrush}"
                                                       Visibility="{Binding IsTransmitting, Converter={StaticResource HiddenWhenFalse}}" />
                                        </StackPanel>
                                        <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="{StaticResource LcdDimTextBrush}">
                                            <Run Text="ch " /><Run Text="{Binding MemoryChannel, Mode=OneWay}" />
                                        </TextBlock>
                                    </DockPanel>

                                    <Grid Grid.Row="1" Margin="0,4,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="220" />
                                        </Grid.ColumnDefinitions>
                                        <Viewbox Grid.Column="0" Stretch="Uniform" HorizontalAlignment="Left" MaxHeight="64">
                                            <TextBlock Text="{Binding FrequencyText}" FontFamily="Consolas" FontWeight="Bold"
                                                       Foreground="{StaticResource LcdTextBrush}" />
                                        </Viewbox>
                                        <controls:SMeterBar Grid.Column="1" Value="{Binding SMeterRaw}"
                                                            Height="44" Margin="14,8,0,0" VerticalAlignment="Top" />
                                    </Grid>

                                    <Grid Grid.Row="2">
                                        <controls:ScopeStrip x:Name="Scope" />
                                        <Border Background="#B00A1014" CornerRadius="3"
                                                Visibility="{Binding IsSweeping, Converter={StaticResource VisibleWhenTrue}}">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="SCANNING — RECEIVE INTERRUPTED" FontFamily="Consolas"
                                                           FontSize="14" Foreground="{StaticResource IndicatorOnBrush}"
                                                           HorizontalAlignment="Center" />
                                                <Button Content="CANCEL (Esc)" Style="{StaticResource PanelButton}"
                                                        Command="{Binding CancelSweepCommand}" Margin="0,8,0,0"
                                                        HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <Button Content="A/B" Style="{StaticResource SoftKey}" Margin="3,0"
                                        Command="{Binding SwapVfosCommand}" ToolTip="Swap VFO A and B" />
                                <Button Content="A▶B" Style="{StaticResource SoftKey}" Margin="3,0"
                                        Command="{Binding CopyVfoAToBCommand}" ToolTip="Copy VFO A to B" />
                                <Button Content="B▶A" Style="{StaticResource SoftKey}" Margin="3,0"
                                        Command="{Binding CopyVfoBToACommand}" ToolTip="Copy VFO B to A" />
                                <Button Content="MODE" Style="{StaticResource SoftKey}" Margin="3,0"
                                        Command="{Binding ModeCommand}" />
                                <Button Content="BAND ▼" Style="{StaticResource SoftKey}" Margin="12,0,3,0"
                                        Command="{Binding BandDownCommand}" />
                                <Button Content="BAND ▲" Style="{StaticResource SoftKey}" Margin="3,0"
                                        Command="{Binding BandUpCommand}" />
                                <Button Content="{Binding SpanText}" Style="{StaticResource SoftKey}" Margin="12,0,3,0"
                                        Command="{Binding SpanCommand}" ToolTip="Sweep/scan span around the VFO" />
                                <Button Content="SWEEP" Style="{StaticResource SoftKey}" Margin="3,0"
                                        Command="{Binding SweepCommand}"
                                        ToolTip="One-shot band scope across the SPAN. Interrupts receive." />
                            </StackPanel>
                        </Grid>

                        <!-- Right: main dial + fine step + MOX -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <controls:RotaryDial x:Name="VfoDial" Grid.Row="0"
                                                 MaxWidth="280" MaxHeight="280"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center" />

                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <Button Content="◂ STEP" Style="{StaticResource PanelButton}"
                                        Command="{Binding FineDownCommand}"
                                        ToolTip="One radio dial step down (FrequencyDown)" />
                                <Button Content="STEP ▸" Style="{StaticResource PanelButton}" Margin="6,0,0,0"
                                        Command="{Binding FineUpCommand}"
                                        ToolTip="One radio dial step up (FrequencyUp)" />
                            </StackPanel>

                            <DockPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,8,0,0">
                                <Ellipse Width="14" Height="14" Margin="0,0,10,0" VerticalAlignment="Center"
                                         Fill="{Binding IsTransmitting, Converter={StaticResource TxLampBrush}}">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="Red" BlurRadius="10" ShadowDepth="0" Opacity="0.8" />
                                    </Ellipse.Effect>
                                </Ellipse>
                                <Button Content="{Binding MoxText}" Style="{StaticResource MoxButton}"
                                        Tag="{Binding IsMoxArmed}" Command="{Binding MoxCommand}" MinWidth="90"
                                        ToolTip="Manual transmit. First press arms, second press keys the radio." />
                            </DockPanel>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ============ AUDIO LAB ============ -->
            <TabItem Header="AUDIO LAB">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
                        <TextBlock Text="SOURCE" Foreground="{StaticResource LcdDimTextBrush}" FontFamily="Consolas"
                                   VerticalAlignment="Center" DockPanel.Dock="Left" />
                        <ComboBox x:Name="AudioDeviceBox" MinWidth="240" Margin="10,0,0,0" DockPanel.Dock="Left"
                                  ToolTip="System audio (loopback) hears whatever Windows is playing — the rig's USB audio or that YouTube video. The rest are real inputs (mics, line-in)." />
                        <ToggleButton x:Name="AudioToggle" Content="START CAPTURE" Style="{StaticResource PanelToggle}"
                                      Margin="10,0,0,0" Checked="OnAudioToggle" Unchecked="OnAudioToggle"
                                      DockPanel.Dock="Left" />
                        <TextBlock x:Name="AudioStatus" Foreground="{StaticResource LcdDimTextBrush}"
                                   VerticalAlignment="Center" Margin="12,0" DockPanel.Dock="Left" />
                    </DockPanel>

                    <controls:WaveformView x:Name="WaveView" Grid.Row="1" Margin="0,0,0,8" />
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <controls:SpectrumView x:Name="SpecView" Grid.Column="0" Margin="0,0,4,0" />
                        <controls:WaterfallView x:Name="FallView" Grid.Column="1" Margin="4,0,0,0" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ SCANNER ============ -->
            <TabItem Header="SCANNER">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Margin="0,0,10,0">
                        <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,8">
                            <Button Content="{Binding SpanText}" Style="{StaticResource PanelButton}"
                                    Command="{Binding SpanCommand}" DockPanel.Dock="Left"
                                    ToolTip="Scan width around the current VFO" />
                            <Button Content="SWEEP" Style="{StaticResource PanelButton}" Margin="8,0,0,0"
                                    Command="{Binding SweepCommand}" DockPanel.Dock="Left" />
                            <Button Content="FIND CHATTER" Style="{StaticResource PanelButton}" Margin="8,0,0,0"
                                    Command="{Binding ChatterCommand}" DockPanel.Dock="Left"
                                    ToolTip="Scan the span and list active frequencies (also uses the radio's busy flag)" />
                            <Button Content="HEATMAP" Style="{StaticResource PanelButton}" Margin="8,0,0,0"
                                    Command="{Binding HeatmapCommand}" DockPanel.Dock="Left"
                                    ToolTip="Continuous sweep passes painting frequency × time — duty-cycled stations show as dashed stripes. Esc stops. Tip: run TESTS → INITIALIZE first for faster passes." />
                            <Button Content="CANCEL (Esc)" Style="{StaticResource PanelButton}" Margin="8,0,0,0"
                                    Command="{Binding CancelSweepCommand}" DockPanel.Dock="Left" />
                        </DockPanel>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <controls:ScopeStrip x:Name="BigScope" Grid.Row="0" Margin="0,0,0,4" />
                            <controls:HeatmapView x:Name="Heatmap" Grid.Row="1" Margin="0,4,0,0" />
                        </Grid>
                    </DockPanel>

                    <DockPanel Grid.Column="1">
                        <TextBlock DockPanel.Dock="Top" Text="CHATTER — click to tune" FontFamily="Consolas"
                                   Foreground="{StaticResource IndicatorOnBrush}" Margin="0,0,0,6" />
                        <ListBox x:Name="ChatterList" ItemsSource="{Binding ChatterHits}"
                                 Background="{StaticResource LcdBackgroundBrush}" BorderThickness="0"
                                 Foreground="{StaticResource LcdAccentBrush}"
                                 FontFamily="Consolas" FontSize="13"
                                 SelectionChanged="OnChatterPick">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" Margin="2" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ============ MEMORY ============ -->
            <TabItem Header="MEMORY">
                <views:MemoryPanel x:Name="Memory" />
            </TabItem>

            <!-- ============ CW & MESSAGES ============ -->
            <TabItem Header="CW &amp; MSG">
                <views:CwPanel x:Name="Cw" />
            </TabItem>

            <!-- ============ METERS ============ -->
            <TabItem Header="METERS">
                <views:MetersPanel x:Name="Meters" />
            </TabItem>

            <!-- ============ FUNCTIONS ============ -->
            <TabItem Header="FUNCTIONS">
                <views:FunctionsPanel x:Name="Functions" />
            </TabItem>

            <!-- ============ TESTS ============ -->
            <TabItem Header="TESTS">
                <views:TestsPanel x:Name="Tests" />
            </TabItem>

            <!-- ============ CONSOLE ============ -->
            <TabItem Header="CONSOLE">
                <views:ConsolePanel x:Name="Console" />
            </TabItem>
        </TabControl>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="2" Background="{StaticResource StatusBarBrush}" Padding="12,5">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource StatusTextBrush}"
                       FontFamily="Segoe UI" FontSize="12" TextTrimming="CharacterEllipsis" />
        </Border>

        <!-- ===== Disco mode (1986) ===== -->
        <controls:DiscoOverlay x:Name="Disco" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed" />
    </Grid>
</Window>
