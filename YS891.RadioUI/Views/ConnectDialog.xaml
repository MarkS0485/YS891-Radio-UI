<Window x:Class="YS891.RadioUI.Views.ConnectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect to radio"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource FasciaBrush}"
        Foreground="{StaticResource ButtonTextBrush}">
    <StackPanel Margin="16">
        <TextBlock Text="Where is the radio?" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" />

        <RadioButton x:Name="SerialOption" Content="Serial COM port (real FT-891)"
                     Foreground="{StaticResource ButtonTextBrush}" Margin="0,2" />
        <DockPanel Margin="22,4,0,8" LastChildFill="False">
            <ComboBox x:Name="ComPortBox" Width="120" DockPanel.Dock="Left" />
            <Button x:Name="RefreshPortsButton" Content="Refresh" Margin="8,0,0,0"
                    Style="{StaticResource PanelButton}" Click="OnRefreshPorts" DockPanel.Dock="Left" />
        </DockPanel>

        <RadioButton x:Name="TcpOption" Content="TCP (external FT891.Simulator or bridge)"
                     Foreground="{StaticResource ButtonTextBrush}" Margin="0,2" />
        <DockPanel Margin="22,4,0,8" LastChildFill="False">
            <TextBox x:Name="HostBox" Width="140" DockPanel.Dock="Left" />
            <TextBlock Text=":" Margin="4,2" DockPanel.Dock="Left" />
            <TextBox x:Name="PortBox" Width="60" DockPanel.Dock="Left" />
        </DockPanel>

        <RadioButton x:Name="BuiltInOption" Content="Built-in simulator (no hardware needed)"
                     Foreground="{StaticResource ButtonTextBrush}" Margin="0,2" />

        <TextBlock x:Name="ValidationText" Foreground="{StaticResource MeterRedBrush}"
                   Margin="0,8,0,0" TextWrapping="Wrap" Visibility="Collapsed" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Connect" MinWidth="84" Style="{StaticResource PanelButton}"
                    IsDefault="True" Click="OnConnect" />
            <Button Content="Cancel" MinWidth="70" Margin="8,0,0,0" Style="{StaticResource PanelButton}"
                    IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>
