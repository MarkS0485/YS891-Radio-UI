<UserControl x:Class="YS891.RadioUI.Views.FunctionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource ButtonTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource ButtonTextBrush}" />
            <Setter Property="Margin" Value="0,4" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ButtonTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="IsSnapToTickEnabled" Value="True" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,2" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- RECEIVER -->
            <GroupBox Grid.Column="0" Header="RECEIVER">
                <StackPanel>
                    <CheckBox x:Name="PreampCheck" Content="Preamp (IPO off)" Click="OnPreamp" />
                    <CheckBox x:Name="AttCheck" Content="Attenuator" Click="OnAtt" />
                    <TextBlock x:Name="NrLevelLabel" Text="NR level" Margin="0,6,0,0" />
                    <Slider x:Name="NrLevelSlider" />
                    <TextBlock x:Name="NbLevelLabel" Text="NB level" />
                    <Slider x:Name="NbLevelSlider" />
                    <TextBlock x:Name="MonitorLabel" Text="Monitor level" />
                    <Slider x:Name="MonitorSlider" />
                    <CheckBox x:Name="IfShiftCheck" Content="IF shift" Margin="0,6,0,0" Click="OnIfShift" />
                    <TextBlock x:Name="IfShiftLabel" Text="Shift 0 Hz" />
                    <Slider x:Name="IfShiftSlider" Minimum="-1200" Maximum="1200" TickFrequency="20" />
                    <CheckBox x:Name="ClarCheck" Content="Clarifier (RIT)" Margin="0,6,0,0" Click="OnClarifier" />
                    <TextBlock x:Name="ClarLabel" Text="Offset 0 Hz" />
                    <Slider x:Name="ClarSlider" Minimum="-3000" Maximum="3000" TickFrequency="10" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="CLAR −10" Style="{StaticResource PanelButton}" Click="OnClarDown" Margin="0,0,4,0" />
                        <Button Content="CLAR +10" Style="{StaticResource PanelButton}" Click="OnClarUp" Margin="0,0,4,0" />
                        <Button Content="CLEAR" Style="{StaticResource PanelButton}" Click="OnClarClear" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- DSP -->
            <GroupBox Grid.Column="1" Header="DSP">
                <StackPanel>
                    <CheckBox x:Name="AutoNotchCheck" Content="Auto notch (DNF)" Click="OnAutoNotch" />
                    <CheckBox x:Name="ManualNotchCheck" Content="Manual notch" Click="OnManualNotch" />
                    <TextBlock x:Name="NotchFreqLabel" Text="Notch 1500 Hz" />
                    <Slider x:Name="NotchFreqSlider" Minimum="1" Maximum="320" TickFrequency="1" />
                    <CheckBox x:Name="ContourCheck" Content="Contour" Margin="0,6,0,0" Click="OnContour" />
                    <TextBlock x:Name="ContourFreqLabel" Text="Contour freq" />
                    <Slider x:Name="ContourFreqSlider" Minimum="10" Maximum="3200" TickFrequency="10" />
                    <TextBlock x:Name="BandwidthLabel" Text="IF bandwidth" Margin="0,6,0,0" />
                    <Slider x:Name="BandwidthSlider" Minimum="0" Maximum="21" TickFrequency="1" />
                </StackPanel>
            </GroupBox>

            <!-- TRANSMITTER -->
            <GroupBox Grid.Column="2" Header="TRANSMITTER">
                <StackPanel>
                    <TextBlock x:Name="PowerLabel" Text="TX power" />
                    <Slider x:Name="PowerSlider" />
                    <CheckBox x:Name="ProcCheck" Content="Speech processor" Margin="0,6,0,0" Click="OnProc" />
                    <TextBlock x:Name="ProcLevelLabel" Text="Proc level" />
                    <Slider x:Name="ProcLevelSlider" Minimum="0" Maximum="100" TickFrequency="1" />
                    <CheckBox x:Name="VoxCheck" Content="VOX" Margin="0,6,0,0" Click="OnVox" />
                    <TextBlock x:Name="VoxGainLabel" Text="VOX gain" />
                    <Slider x:Name="VoxGainSlider" />
                    <TextBlock x:Name="VoxDelayLabel" Text="VOX delay" />
                    <Slider x:Name="VoxDelaySlider" />
                    <TextBlock Text="Antenna tuner" Margin="0,6,0,0" />
                    <ComboBox x:Name="TunerCombo" SelectionChanged="OnTuner"
                              ToolTip="START keys the radio briefly to tune — dummy load or clear frequency!" />
                    <TextBlock Text="Repeater shift" Margin="0,6,0,0" />
                    <ComboBox x:Name="ShiftCombo" SelectionChanged="OnShift"
                              ToolTip="Shift direction over CAT; the offset magnitude is a radio menu setting, not a CAT parameter." />
                    <CheckBox x:Name="CtcssCheck" Content="CTCSS" Margin="0,6,0,0" Click="OnCtcss" />
                    <TextBlock x:Name="CtcssNumLabel" Text="Tone #0" />
                    <Slider x:Name="CtcssNumSlider" TickFrequency="1" />
                </StackPanel>
            </GroupBox>

            <!-- SYSTEM -->
            <GroupBox Grid.Column="3" Header="SYSTEM / DISPLAY">
                <StackPanel>
                    <TextBlock x:Name="DimmerLabel" Text="Dimmer" />
                    <Slider x:Name="DimmerSlider" />
                    <CheckBox x:Name="FastStepCheck" Content="Fast step" Click="OnFastStep" />
                    <CheckBox x:Name="AutoInfoCheck" Content="Auto information (AI)" Click="OnAutoInfo"
                              ToolTip="Radio pushes unsolicited state frames — the library normally polls instead" />
                    <TextBlock Text="Scan" Margin="0,6,0,0" />
                    <ComboBox x:Name="ScanCombo" SelectionChanged="OnScan"
                              ToolTip="Up/Down starts the radio scanning from the current frequency" />
                    <Separator Margin="0,10" />
                    <Button Content="POWER OFF RADIO" Style="{StaticResource PanelButton}"
                            Click="OnPowerOff"
                            ToolTip="Sends PS0 — the radio switches off. You'll need the front button (or PS1 over a kept-alive port) to wake it." />
                </StackPanel>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</UserControl>
