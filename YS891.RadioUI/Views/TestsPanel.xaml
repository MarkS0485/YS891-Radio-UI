<UserControl x:Class="YS891.RadioUI.Views.TestsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
            <Button x:Name="RunButton" Content="RUN FUNCTION TESTS" Style="{StaticResource PanelButton}"
                    Click="OnRun" DockPanel.Dock="Left"
                    ToolTip="Calls every read command in the library, one tile per function" />
            <Button x:Name="InitButton" Content="INITIALIZE (calibrate timing)" Style="{StaticResource PanelButton}"
                    Click="OnInitialize" Margin="8,0,0,0" DockPanel.Dock="Left"
                    ToolTip="Times ID; round-trips and tunes InterCommandDelayMs to this radio" />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                <Rectangle Width="12" Height="12" Fill="#FF00BFFF" /><TextBlock Text=" pending   " Foreground="{StaticResource ButtonTextBrush}" FontSize="11" />
                <Rectangle Width="12" Height="12" Fill="#FFFFD000" /><TextBlock Text=" executing   " Foreground="{StaticResource ButtonTextBrush}" FontSize="11" />
                <Rectangle Width="12" Height="12" Fill="#FF3DDC5A" /><TextBlock Text=" pass   " Foreground="{StaticResource ButtonTextBrush}" FontSize="11" />
                <Rectangle Width="12" Height="12" Fill="#FFFF453A" /><TextBlock Text=" fail" Foreground="{StaticResource ButtonTextBrush}" FontSize="11" />
            </StackPanel>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="TileHost">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="86" Height="62" Margin="3" CornerRadius="4"
                                Background="{Binding Brush}" Cursor="Hand"
                                MouseLeftButtonUp="OnTileClick"
                                ToolTip="{Binding Tooltip}">
                            <TextBlock Text="{Binding Name}" FontFamily="Consolas" FontSize="10"
                                       Foreground="#FF101113" FontWeight="Bold" TextWrapping="Wrap"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       TextAlignment="Center" Margin="3" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{StaticResource LcdBackgroundBrush}" CornerRadius="4"
                Padding="10,6" Margin="0,8,0,0">
            <TextBlock x:Name="Detail" FontFamily="Consolas" FontSize="12"
                       Foreground="{StaticResource LcdTextBrush}" TextWrapping="Wrap"
                       Text="Connect, then RUN FUNCTION TESTS to walk the whole library. Click a tile for its result." />
        </Border>
    </Grid>
</UserControl>
