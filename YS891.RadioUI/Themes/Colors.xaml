<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Fascia: the FT-891's dark charcoal body -->
    <Color x:Key="FasciaTopColor">#FF3A3D40</Color>
    <Color x:Key="FasciaBottomColor">#FF1B1D1F</Color>
    <LinearGradientBrush x:Key="FasciaBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource FasciaTopColor}" Offset="0" />
        <GradientStop Color="{StaticResource FasciaBottomColor}" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="BezelBrush" Color="#FF0E0F10" />
    <SolidColorBrush x:Key="PanelEdgeBrush" Color="#FF55585C" />

    <!-- LCD: white-on-near-black like the real display -->
    <SolidColorBrush x:Key="LcdBackgroundBrush" Color="#FF0A1014" />
    <SolidColorBrush x:Key="LcdTextBrush" Color="#FFE8F4FF" />
    <SolidColorBrush x:Key="LcdDimTextBrush" Color="#FF5C7585" />
    <SolidColorBrush x:Key="LcdAccentBrush" Color="#FF7FD4FF" />
    <SolidColorBrush x:Key="LcdGridBrush" Color="#FF15222B" />

    <!-- Indicators -->
    <SolidColorBrush x:Key="TxActiveBrush" Color="#FFFF2A1E" />
    <SolidColorBrush x:Key="TxIdleBrush" Color="#FF3A1210" />
    <SolidColorBrush x:Key="IndicatorOnBrush" Color="#FFFFC940" />
    <SolidColorBrush x:Key="IndicatorOffBrush" Color="#FF233038" />

    <!-- Meter ramp -->
    <SolidColorBrush x:Key="MeterGreenBrush" Color="#FF3DDC5A" />
    <SolidColorBrush x:Key="MeterAmberBrush" Color="#FFFFB938" />
    <SolidColorBrush x:Key="MeterRedBrush" Color="#FFFF453A" />

    <!-- Buttons -->
    <LinearGradientBrush x:Key="ButtonFaceBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF4A4E52" Offset="0" />
        <GradientStop Color="#FF2A2D30" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ButtonPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF202326" Offset="0" />
        <GradientStop Color="#FF34373A" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ButtonTextBrush" Color="#FFE6E8EA" />
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FF101113" />

    <!-- Knobs -->
    <RadialGradientBrush x:Key="KnobFaceBrush" GradientOrigin="0.35,0.3">
        <GradientStop Color="#FF5A5E63" Offset="0" />
        <GradientStop Color="#FF2E3134" Offset="0.7" />
        <GradientStop Color="#FF17181A" Offset="1" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="KnobRimBrush" GradientOrigin="0.5,0.4">
        <GradientStop Color="#FF6E7376" Offset="0" />
        <GradientStop Color="#FF1F2123" Offset="1" />
    </RadialGradientBrush>
    <SolidColorBrush x:Key="KnobTickBrush" Color="#FF9BA1A7" />
    <SolidColorBrush x:Key="KnobMarkBrush" Color="#FFE8F4FF" />

    <SolidColorBrush x:Key="StatusBarBrush" Color="#FF141618" />
    <SolidColorBrush x:Key="StatusTextBrush" Color="#FFB8BEC4" />
</ResourceDictionary>
