<UserControl x:Class="YS891.RadioUI.Controls.WaveformView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource LcdGridBrush}" CornerRadius="3" ClipToBounds="True">
        <Grid>
            <Viewbox Stretch="Fill">
                <Canvas Width="480" Height="120" Background="Transparent">
                    <Line X1="0" Y1="60" X2="480" Y2="60" Stroke="{StaticResource LcdDimTextBrush}"
                          StrokeThickness="0.5" Opacity="0.5" />
                    <Polyline x:Name="Trace" StrokeThickness="1.2"
                              Stroke="{StaticResource MeterGreenBrush}" />
                </Canvas>
            </Viewbox>
            <TextBlock Text="AUDIO WAVE" FontFamily="Consolas" FontSize="11"
                       Foreground="{StaticResource LcdDimTextBrush}"
                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6,3" />
            <TextBlock x:Name="NoAudioHint" Text="no audio — pick a device and press AUDIO"
                       FontFamily="Consolas" FontSize="11"
                       Foreground="{StaticResource LcdDimTextBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
    </Border>
</UserControl>
