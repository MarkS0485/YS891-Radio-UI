<UserControl x:Class="YS891.RadioUI.Controls.SMeterBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <UniformGrid x:Name="Segments" Rows="1" Grid.Row="0" />
        <TextBlock x:Name="Label" Grid.Row="1" HorizontalAlignment="Right"
                   FontFamily="Consolas" FontSize="12"
                   Foreground="{StaticResource LcdAccentBrush}" Margin="0,2,0,0" />
    </Grid>
</UserControl>
