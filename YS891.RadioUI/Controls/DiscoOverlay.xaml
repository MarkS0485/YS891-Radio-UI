<UserControl x:Class="YS891.RadioUI.Controls.DiscoOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="True">
    <Grid ClipToBounds="True">
        <Border x:Name="Strobe" Opacity="0.18" />
        <Canvas x:Name="Lights" />

        <!-- The dance floor: classic light-up tiles -->
        <UniformGrid x:Name="Floor" Rows="2" Columns="14" VerticalAlignment="Bottom"
                     Height="72" Margin="0,0,0,34" Opacity="0.85" />

        <Border x:Name="MarqueeBand" VerticalAlignment="Bottom" Height="34"
                Background="#CC000000" BorderBrush="Magenta" BorderThickness="0,2,0,0">
            <Canvas ClipToBounds="True">
                <TextBlock x:Name="Marquee" Canvas.Top="4"
                           FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                           Foreground="Yellow"
                           Text="★ DISCO MODE ★ NEVER GONNA GIVE YOU UP ★ NEVER GONNA TURN AROUND ★ YS891 MEGAMIX '86 ★" />
            </Canvas>
        </Border>

        <!-- The DJ booth -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,10,10,0">
            <TextBlock x:Name="NowPlaying" Foreground="Cyan" FontFamily="Consolas" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,10,0" />
            <Button x:Name="LoadTrack" Content="♫ LOAD TRACK"
                    FontFamily="Consolas" FontWeight="Bold"
                    Background="Cyan" Foreground="Black" BorderBrush="Magenta" BorderThickness="3"
                    Padding="10,4" Click="OnLoadTrack"
                    ToolTip="Pick an MP3/WAV — it plays through the speakers; turn on AUDIO LAB loopback capture and the lights dance to it" />
            <Button x:Name="StopTrack" Content="■" Margin="6,0,0,0"
                    FontFamily="Consolas" FontWeight="Bold" Visibility="Collapsed"
                    Background="OrangeRed" Foreground="Black" BorderBrush="Yellow" BorderThickness="3"
                    Padding="10,4" Click="OnStopTrack" />
            <Button x:Name="HitSingle" Content="▶ PLAY HIT SINGLE" Margin="6,0,0,0"
                    FontFamily="Consolas" FontWeight="Bold"
                    Background="Magenta" Foreground="Yellow" BorderBrush="Cyan" BorderThickness="3"
                    Padding="10,4" Click="OnHitSingle" />
        </StackPanel>
    </Grid>
</UserControl>
